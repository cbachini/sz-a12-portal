# ---------------------------------------------------------------
# Segredos e credenciais — NUNCA commitar
# ---------------------------------------------------------------
.env
*.env.local
*.env.*.local

# ---------------------------------------------------------------
# Uploads do WordPress (armazenados em volume Docker / S3 em prod)
# ---------------------------------------------------------------
wp-content/uploads/

# ---------------------------------------------------------------
# Dependências PHP via Composer — geradas em build / install local
# ---------------------------------------------------------------
vendor/
composer.lock

# ---------------------------------------------------------------
# Plugins gerenciados via Composer (WPackagist) — não versionar
# ---------------------------------------------------------------
wp-content/plugins/s3-uploads/
wp-content/plugins/advanced-custom-fields/
wp-content/plugins/polylang/
wp-content/plugins/wordpress-seo/
wp-content/plugins/elementor/

# ---------------------------------------------------------------
# Temas gerenciados via Composer (WPackagist) — não versionar
# ---------------------------------------------------------------
wp-content/themes/hello-elementor/
wp-content/themes/twentytwentythree/
wp-content/themes/twentytwentyfour/
wp-content/themes/twentytwentyfive/

# ---------------------------------------------------------------
# Plugins removidos da stack — fora da arquitetura definida
# ---------------------------------------------------------------
wp-content/plugins/akismet/
wp-content/plugins/google-site-kit/
wp-content/plugins/duplicator/
wp-content/plugins/duplicate-menu/
wp-content/plugins/duplicate-post/
wp-content/plugins/wp-security-audit-log/

# ---------------------------------------------------------------
# Logs
# ---------------------------------------------------------------
logs/*.log
!logs/.gitkeep

# ---------------------------------------------------------------
# Banco de dados local
# ---------------------------------------------------------------
db/dumps/*.sql
db/dumps/*.sql.gz
db/dumps/*.tar.gz

# ---------------------------------------------------------------
# Artefatos locais de migração / backup
# ---------------------------------------------------------------
*_archive.zip
installer.php

# ---------------------------------------------------------------
# macOS
# ---------------------------------------------------------------
.DS_Store
.AppleDouble
.LSOverride

# ---------------------------------------------------------------
# IDEs
# ---------------------------------------------------------------
.vscode/
.idea/
*.swp
*.swo

# ---------------------------------------------------------------
# Node (caso algum tooling local use)
# ---------------------------------------------------------------
node_modules/
config/ssl/*.key
config/ssl/*.crt

# ---------------------------------------------------------------
# Arquivos sensíveis de credenciais AWS (Dedalus)
# ---------------------------------------------------------------
docs/dedalus/*accessKeys*.csv
