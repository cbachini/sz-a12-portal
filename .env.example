# Portal A12 — Variáveis de ambiente LOCAL
# Copie para .env e preencha antes de rodar docker compose up
# NUNCA commite o arquivo .env

# ---------------------------------------------------------------
# Banco de dados (MySQL local)
# ---------------------------------------------------------------
DB_NAME=a12_local
DB_USER=a12
DB_PASSWORD=troque_esta_senha
DB_ROOT_PASSWORD=troque_root_senha

# ---------------------------------------------------------------
# WordPress
# ---------------------------------------------------------------
WP_TABLE_PREFIX=wp_

# Gere as chaves em: https://api.wordpress.org/secret-key/1.1/salt/
WP_AUTH_KEY=coloque_chave_aqui
WP_SECURE_AUTH_KEY=coloque_chave_aqui
WP_LOGGED_IN_KEY=coloque_chave_aqui
WP_NONCE_KEY=coloque_chave_aqui
WP_AUTH_SALT=coloque_chave_aqui
WP_SECURE_AUTH_SALT=coloque_chave_aqui
WP_LOGGED_IN_SALT=coloque_chave_aqui
WP_NONCE_SALT=coloque_chave_aqui

# ---------------------------------------------------------------
# Portas locais (evite conflito com outros serviços)
# ---------------------------------------------------------------
WP_PORT=8080
MYSQL_PORT=3306
PMA_PORT=8081
